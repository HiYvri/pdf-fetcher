{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "zotero-types"]
  },
  "include": ["src/**/*.ts", "typings/**/*.d.ts", "zotero-plugin.config.ts"]
}
