{
  "name": "pdf-fetcher",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "description": "Fetch PDFs from JLYL services and attach them to Zotero items.",
  "author": "yuri cao",
  "homepage": "https://github.com/HiYvri/pdf-fetcher",
  "repository": {
    "type": "git",
    "url": "https://github.com/HiYvri/pdf-fetcher.git"
  },
  "config": {
    "addonName": "pdf-fetcher",
    "addonID": "pdf-fetcher@yuric.local",
    "addonRef": "pdf-fetcher",
    "addonInstance": "pdfFetcher",
    "prefsPrefix": "extensions.zotero.pdfFetcher"
  },
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  }
}
